algorithm MatrixDemo
var
    matrix: array[2][3] of integer;
    i, j, sum: integer;
begin
    matrix[0][0] := 1;
    matrix[0][1] := 2;
    matrix[0][2] := 3;
    matrix[1][0] := 4;
    matrix[1][1] := 5;
    matrix[1][2] := 6;

    sum := 0;
    for i from 0 to 1 do
        for j from 0 to 2 do
            sum := sum + matrix[i][j];
        endfor
    endfor

    write("matrix sum:");
    write(sum);
end.
