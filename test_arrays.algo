algorithm TestArrays
var
    numbers: array[5] of integer;
    i: integer;
    sum: integer;

begin
    numbers[0] := 10;
    numbers[1] := 20;
    numbers[2] := 30;
    numbers[3] := 40;
    numbers[4] := 50;
    
    sum := 0;
    for i from 0 to 4 do
        sum := sum + numbers[i];
    endfor
    
    write("Array elements:");
    for i from 0 to 4 do
        write(numbers[i]);
    endfor
    
    write("Sum of array:");
    write(sum);
end.
