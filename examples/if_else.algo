algorithm CheckNumber
var
    num: integer;
begin
    num := 15;

    if num > 10 then
        write("number is greater than 10");
    else
        write("number is less than or equal to 10");
    endif

    if num mod 2 = 0 then
        write("number is even");
    else
        write("number is odd");
    endif
end.
